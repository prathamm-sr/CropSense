# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data — don't commit large CSVs (use DVC or Git LFS later)
data/*.csv
data/*.parquet

# Saved models — can be large; commit only versioned artifacts intentionally
models/*.joblib
!models/.gitkeep

# Outputs — generated at runtime
outputs/*.npy
outputs/*.png
outputs/*.json
!outputs/.gitkeep

# Env / secrets
.env
.env.*
*.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp